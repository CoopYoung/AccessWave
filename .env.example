# Local dev (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./accesswave.db
# Docker / PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://accesswave:accesswave@postgres:5432/accesswave
SECRET_KEY=change-me-to-a-random-secret-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins (defaults to BASE_URL).
# Example for multi-origin prod: CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:8000

# Celery / Redis (set USE_CELERY=true to enable distributed scanning)
USE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security headers
# Set to true only when the app is served over HTTPS in production.
HSTS_ENABLED=false
# Optional URI to collect CSP violation reports (leave blank to omit).
CSP_REPORT_URI=

# Email notifications (SMTP)
# Leave SMTP_HOST blank (default) to disable all email delivery.
# Example: Gmail via STARTTLS on port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Set SMTP_USE_TLS=true to use implicit TLS (port 465). Default uses STARTTLS (port 587).
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=noreply@accesswave.app
SMTP_FROM_NAME=AccessWave
